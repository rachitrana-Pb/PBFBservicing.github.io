  { key: 'lasik', label: 'Lasik', value: '', ph: 'e.g. Covered if power is +/- 7 D' },\n      { key: 'congenital', label: 'Congenital Disease', value: '', ph: 'Covered / Not Covered' },\n      { key: 'domiciliary', label: 'Domiciliary Hospitalisation', value: '', ph: 'Covered / Not Covered' },\n      { key: 'dayCare', label: 'Day Care Treatment', value: '', ph: 'Covered / Not Covered' },\n      { key: 'cancer', label: 'Cancer Treatment', value: '', ph: 'Covered / Not Covered' },\n      { key: 'ayush', label: 'Ayush Cover', value: '', ph: 'Covered / Not Covered' },\n      { key: 'covid', label: 'Covid 19', value: '', ph: 'Covered / Not Covered' },\n      { key: 'corpBuffer', label: 'Corporate Buffer', value: '', ph: 'Applicable / Not Applicable' },\n      { key: 'newBorn', label: 'New/Born Coverage', value: '', ph: 'e.g. Covered after 180 Days' },\n      { key: 'claimIntimation', label: 'Claim Intimation Clause', value: '', ph: 'Enter clause' },\n      { key: 'claimSubmission', label: 'Claim Submission Clause', value: '', ph: 'Enter clause' },\n    ],\n    rows: [\n      { id: 1, def: 'E+K',       si: '200000', premium: '5678',  baseSI: '200000', topUpSI: '200000', emp: '3828', spouse: '3828', child: '3041', planName: 'Base', lives: '62', ageBand: '18-35', gradeSet: '1', companyPrem: '4200', employeePrem: '1478', warn: '' },\n      { id: 2, def: 'E+S+K3',    si: '400000', premium: '56789', baseSI: '200000', topUpSI: '400000', emp: '5633', spouse: '5633', child: '4785', planName: 'Base + Ayurvedic', lives: '0', ageBand: '36-45', gradeSet: '1', companyPrem: '44000', employeePrem: '12789', warn: '' },\n      { id: 3, def: 'E+S+K4+P4', si: '600000', premium: '45678', baseSI: '400000', topUpSI: '200000', emp: '7241', spouse: '7241', child: '6120', planName: 'Base + Room Rent', lives: '0', ageBand: '46-60', gradeSet: '2', companyPrem: '33000', employeePrem: '12678', warn: '' },\n    ],\n  };\n\n  grp(v) {\n    const d = String(v == null ? '' : v).replace(/[^0-9]/g, '');\n    if (!d) return '';\n    let last3 = d.slice(-3), other = d.slice(0, -3);\n    if (other) last3 = ',' + last3;\n    other = other.replace(/\\B(?=(\\d{2})+(?!\\d))/g, ',');\n    return other + last3;\n  }\n  inr(n) { return '\\u20B9' + this.grp(String(Math.round(n))); }\n\n  words(v) {\n    let n = parseInt(String(v).replace(/[^0-9]/g, ''), 10);\n    if (!n || isNaN(n)) return '';\n    const a = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine', 'Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];\n    const b = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];\n    const two = (x) => x < 20 ? a[x] : (b[Math.floor(x / 10)] + (x % 10 ? ' ' + a[x % 10] : ''));\n    const three = (x) => x >= 100 ? ((a[Math.floor(x / 100)] || '') + ' Hundred' + (x % 100 ? ' ' + two(x % 100) : '')) : two(x);\n    const parts = [];\n    const crore = Math.floor(n / 10000000); n %= 10000000;\n    const lakh = Math.floor(n / 100000); n %= 100000;\n    const thou = Math.floor(n / 1000); n %= 1000;\n    if (crore) parts.push(three(crore) + ' Crore');\n    if (lakh) parts.push(three(lakh) + ' Lakh');\n    if (thou) parts.push(three(thou) + ' Thousand');\n    if (n) parts.push(three(n));\n    return parts.join(' ') + ' Rupees';\n  }\n\n  expandDef(str) {\n    if (!str) return '';\n    const names = { E: 'Employee', S: 'Spouse', K: 'Child', P: 'Parent', SIB: 'Sibling' };\n    const plural = { K: 'Children', P: 'Parents', SIB: 'Siblings' };\n    const parts = [];\n    str.split('+').forEach(tok => {\n      const m = tok.match(/^(SIB|[ESKP])(\\d*)$/i);\n      if (!m) return;\n      const L = m[1].toUpperCase();\n      const n = m[2] ? parseInt(m[2], 10) : 1;\n      parts.push(n > 1 ? (n + ' ' + (plural[L] || names[L])) : names[L]);\n    });\n    return parts.join(', ');\n  }\n\n  formatDef(raw, selfOnly) {\n    raw = (raw || '').toUpperCase().replace(/[^ESKPIB0-9]/g, '');\n    const re = /(SIB)(\\d*)|([ESKP])(\\d*)/g;\n    const seen = {}, order = [];\n    let m;\n    while ((m = re.exec(raw))) {\n      const L = m[1] ? 'SIB' : m[3];\n      const num = m[1] ? m[2] : m[4];\n      if (!(L in seen)) { order.push(L); seen[L] = num; }\n      else if (num !== '') { seen[L] = num; }\n    }\n    const warns = [], parts = [];\n    for (const L of order) {\n      if (selfOnly && L !== 'E') { warns.push('Non-Floater is Self only'); continue; }\n      let n = seen[L] === '' ? 1 : parseInt(seen[L], 10);\n      if (isNaN(n)) n = 1;\n      if (L === 'E' || L === 'S') { if (n > 1) warns.push(L === 'E' ? 'Employee max 1' : 'Spouse max 1'); n = 1; }\n      if (L === 'K') { if (n < 1) n = 1; if (n > 6) { warns.push('Kids capped to 6'); n = 6; } }\n      if (L === 'P') { if (n < 1) n = 1; if (n > 4) { warns.push('Parents capped to 4'); n = 4; } }\n      if (L === 'SIB') { if (n < 1) n = 1; if (n > 4) { warns.push('Siblings capped to 4'); n = 4; } }\n      const disp = L === 'SIB' ? 'Sib' : L;\n      parts.push(disp + (n > 1 ? n : ''));\n    }\n    return { str: parts.join('+'), warns };\n  }\n\n  // Column configuration for the current rater type + Flexi options.\n  columnsFor() {\n    const r = this.state.rater;\n    const topUp = r === 'Flexi/Modular Type' && this.state.flexiTopUp;\n    const plan = r === 'Flexi/Modular Type' && this.state.flexiPlan;\n    const critical = r === 'Flexi/Modular Type' && this.state.addCritical;\n    const parental = r === 'Flexi/Modular Type' && this.state.addParental;\n    const cols = [{ key: 'grade', label: 'Grade ID', kind: 'grade', align: 'center', w: '78px' }];\n    cols.push({ key: 'gradeName', label: 'Grade Name', kind: 'gradeName', align: 'left', w: '1.1fr' });\n\n    if (r === 'Per Life Rate' || r === 'Age Band Wise Rate - Per Life') {\n      if (r === 'Age Band Wise Rate - Per Life') cols.push({ key: 'ageBand', label: 'Age Band', kind: 'text', align: 'left', w: '0.9fr' });\n      cols.push({ key: 'si', label: 'Sum Insured', kind: 'money', align: 'left', w: '1fr' });\n      cols.push({ key: 'emp', label: 'Employee', kind: 'money', align: 'left', w: '1fr' });\n      cols.push({ key: 'spouse', label: 'Spouse', kind: 'money', align: 'left', w: '1fr' });\n      cols.push({ key: 'child', label: 'Child', kind: 'money', align: 'left', w: '1fr' });\n      return { cols, family: 'none', computed: false, errorKey: 'emp' };\n    }\n\n    const split = r === 'Flexi/Modular Type' && this.state.flexiSplit;\n    const familyKind = (r === 'Per Family Rate') ? 'familyFree' : 'familyTyped';\n    const familyLabel = (r === 'Per Family Rate') ? 'Family Scope / Unit' : 'Family Definition';\n    if (r === 'Set of Parent Rate') cols.push({ key: 'gradeSet', label: 'Set', kind: 'text', align: 'center', w: '0.6fr' });\n    cols.push({ key: 'def', label: familyLabel, kind: familyKind, align: 'left', w: '1.6fr' });\n    if (plan) {\n      cols.push({ key: 'planName', label: 'Plan Name', kind: 'text', align: 'left', w: '1.5fr' });\n      cols.push({ key: 'lives', label: 'Lives', kind: 'num', align: 'center', w: '0.6fr' });\n    }\n    if (split && !plan) cols.push({ key: 'lives', label: 'Lives', kind: 'num', align: 'center', w: '0.6fr' });\n    if (topUp) {\n      cols.push({ key: 'baseSI', label: 'Base SI', kind: 'money', align: 'left', w: '1fr' });\n      cols.push({ key: 'topUpSI', label: 'Top-Up SI', kind: 'money', align: 'left', w: '1fr' });\n    } else {\n      cols.push({ key: 'si', label: 'Sum Insured', kind: 'money', align: 'left', w: '1fr' });\n    }\n    if (r === 'Age Band Wise Rate - Per Family') cols.push({ key: 'ageBand', label: 'Age Band', kind: 'text', align: 'left', w: '0.8fr' });\n    if (parental) cols.push({ key: 'parentalSI', label: 'Parental Top-Up SI', kind: 'money', align: 'left', w: '1.3fr' });\n    if (critical) cols.push({ key: 'critSI', label: 'Critical Illness SI', kind: 'money', align: 'left', w: '1.1fr' });\n    if (split) {\n      cols.push({ key: 'companyPrem', label: 'Company Prem', kind: 'money', align: 'right', w: '1fr' });\n      cols.push({ key: 'employeePrem', label: 'Employee Prem', kind: 'money', align: 'right', w: '1fr' });\n    } else {\n      cols.push({ key: 'premium', label: 'Premium (Excl. GST)', kind: 'money', align: 'right', w: '1.1fr' });\n    }\n    cols.push({ key: 'gst', label: 'GST 18%', kind: 'gst', align: 'right', w: '0.85fr' });\n    cols.push({ key: 'gross', label: 'Net Premium', kind: 'gross', align: 'right', w: '1fr' });\n    cols.push({ key: 'remarks', label: 'Remarks', kind: 'text', align: 'left', w: '1.3fr' });\n    return { cols, family: familyKind, computed: true, errorKey: split ? 'employeePrem' : 'premium', split };\n  }\n\n  computeErrors(attempted) {\n    const cfg = this.columnsFor();\n    const r = this.state.rater;\n    const rows = this.state.rows;\n    const topUp = r === 'Flexi/Modular Type' && this.state.flexiTopUp;\n    const critical = r === 'Flexi/Modular Type' && this.state.addCritical;\n    const parental = r === 'Flexi/Modular Type' && this.state.addParental;\n    const plan = r === 'Flexi/Modular Type' && this.state.flexiPlan;\n    const hasAgeBand = cfg.cols.some(c => c.key === 'ageBand');\n    const hasSet = cfg.cols.some(c => c.key === 'gradeSet');\n    const comboExtras = topUp || critical || parental;\n    // Uniqueness is on the full combination, not the Family Definition alone:\n    // base-only -> FD + Sum Insured; with top-up/add-on -> FD + all SI fields.\n    const comboKey = (row) => {\n      const parts = [(row.def || '').trim().toUpperCase()];\n      if (topUp) { parts.push('B' + (row.baseSI || ''), 'T' + (row.topUpSI || '')); }\n      else { parts.push('S' + (row.si || '')); }\n      if (parental) parts.push('PT' + (row.parentalSI || ''));\n      if (critical) parts.push('CI' + (row.critSI || ''));\n      if (plan) parts.push('PL' + (row.planName || '').trim().toLowerCase());\n      if (hasAgeBand) parts.push('AB' + (row.ageBand || '').trim());\n      if (hasSet) parts.push('SET' + (row.gradeSet || '').trim());\n      return parts.join('|');\n    };\n    const counts = {};\n    if (cfg.computed) rows.forEach(x => { if ((x.def || '').trim()) { const k = comboKey(x); counts[k] = (counts[k] || 0) + 1; } });\n    return rows.map(row => {\n      let defError = '', amountError = '';\n      if (cfg.family === 'familyTyped') {\n        const tokens = (row.def || '').split('+').filter(Boolean);\n        if (!row.def) defError = attempted ? 'Add at least one member to the family definition' : '';\n        else if (row.warn) defError = row.warn;\n        else {\n          const allowed = this.scopeSet();\n          const nm = { E: 'Employee', S: 'Spouse', K: 'Child', P: 'Parent', SIB: 'Sibling' };\n          const bad = tokens.map(t => t.replace(/[0-9]/g, '').toUpperCase()).find(m => !allowed.includes(m));\n          if (bad) defError = nm[bad] + ' (' + (bad === 'SIB' ? 'Sib' : bad) + ') is outside the selected Family Definition scope · ' + this.state.familyDef;\n        }\n      } else if (cfg.family === 'familyFree') {\n        if (!row.def && attempted) defError = 'Enter a family scope / unit';\n      }\n      if (!defError && cfg.computed && (row.def || '').trim() && counts[comboKey(row)] > 1) {\n        defError = comboExtras\n          ? 'Duplicate — same Family Definition + SI combination already exists'\n          : 'Duplicate — same Family Definition & Sum Insured already exists';\n      }\n      if (cfg.computed) {\n        const si = Number(row.si) || 0, prem = Number(row.premium) || 0;\n        if (cfg.split) {\n          if ((row.companyPrem === '' || row.employeePrem === '') && attempted) amountError = 'Enter Company & Employee premium';\n        } else if (topUp) {\n          if ((row.baseSI === '' || row.topUpSI === '' || row.premium === '') && attempted) amountError = 'Enter Base SI, Top-Up SI & Premium';\n        } else {\n          if (row.si === '' || row.premium === '') { if (attempted) amountError = 'Enter Sum Insured & Premium'; }\n          else if (prem === si) amountError = 'Premium cannot equal Sum Insured';\n          else if (prem > si) amountError = 'Premium must be less than Sum Insured';\n        }\n      } else {\n        if (attempted && (row.si === '' || row.emp === '')) amountError = 'Enter SI & member premiums';\n      }\n      return { defError, amountError };\n    });\n  }\n\n  togglePolicy() { this.setState({ policyOpen: !this.state.policyOpen }); }\n  setFeature(key, val) {\n    const features = this.state.features.map(f => f.key === key ? { ...f, value: val } : f);\n    this.setState({ features, policySaved: false });\n  }\n  removeFeature(key) {\n    this.setState({ features: this.state.features.filter(f => f.key !== key), policySaved: false });\n  }\n  beginAddFeature() { this.setState({ addingFeature: true, newFieldName: '', newFieldValue: '' }); }\n  cancelAddFeature() { this.setState({ addingFeature: false, newFieldName: '', newFieldValue: '' }); }\n  confirmAddFeature() {\n    const name = this.state.newFieldName.trim();\n    if (!name) return;\n    const key = 'custom_' + Date.now();\n    const features = this.state.features.concat([{ key, label: name, value: this.state.newFieldValue, ph: 'Enter value', custom: true }]);\n    this.setState({ features, addingFeature: false, newFieldName: '', newFieldValue: '', policySaved: false });\n  }\n  savePolicy() { this.setState({ policySaved: true }); }\n\n  toggleUpload() { this.setState({ uploadOpen: !this.state.uploadOpen }); }\n  closeUpload() { this.setState({ uploadOpen: false }); }\n\n  downloadTemplate() {\n    const cfg = this.columnsFor();\n    const s = this.state;\n    const esc = (v) => '\"' + String(v == null ? '' : v).replace(/\"/g, '\"\"') + '\"';\n    const lines = [];\n    lines.push(esc('Rater Type') + ',' + esc(s.rater));\n    lines.push(esc('Family Definition') + ',' + esc(s.familyDef));\n    lines.push(esc('Coverage') + ',' + esc(s.coverage));\n    lines.push(esc('Sum Insured Type') + ',' + 