ning: rows.length < 2,\n      summaryText,\n\n      onSave: () => this.onSave(),\n      onCancel: () => this.onCancel(),\n      addRow: () => this.addRow(),\n      toggleCollapse: () => this.toggleCollapse(),\n      saved: s.saved,\n      showSaveError: s.attempted && !s.saved,\n      saveIssues: s.saveIssues,\n      saveErrorHead: s.saveIssues.length === 1\n        ? 'Please resolve 1 issue before saving:'\n        : 'Please resolve ' + s.saveIssues.length + ' issues before saving:',\n\n      policyOpen: s.policyOpen,\n      togglePolicy: () => this.togglePolicy(),\n      chevronTransform: s.policyOpen ? 'rotate(45deg)' : 'rotate(-45deg)',\n      chevronMargin: s.policyOpen ? '-3px' : '3px',\n      policyCount: s.features.length,\n      features: s.features.map(f => ({\n        label: f.label, value: f.value, placeholder: f.ph, custom: !!f.custom,\n        onChange: (e) => this.setFeature(f.key, e.target.value),\n        onRemove: () => this.removeFeature(f.key),\n      })),\n      addingFeature: s.addingFeature,\n      showAddCta: !s.addingFeature,\n      onAddFeature: () => this.beginAddFeature(),\n      onCancelFeature: () => this.cancelAddFeature(),\n      onConfirmFeature: () => this.confirmAddFeature(),\n      newFieldName: s.newFieldName,\n      newFieldValue: s.newFieldValue,\n      onNewName: (e) => this.setState({ newFieldName: e.target.value }),\n      onNewValue: (e) => this.setState({ newFieldValue: e.target.value }),\n      addDisabled: !s.newFieldName.trim(),\n      addError: (s.addingFeature && !s.newFieldName.trim()) ? '' : '',\n      confirmBtnStyle: 'height:44px;padding:0 20px;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;'\n        + (s.newFieldName.trim() ? 'background:#2563eb;color:#fff;' : 'background:#c7d2e0;color:#fff;cursor:not-allowed;'),\n      onSavePolicy: () => this.savePolicy(),\n      policySaved: s.policySaved,\n      policySavedMsg: s.features.length + ' policy features saved to the corporate record 